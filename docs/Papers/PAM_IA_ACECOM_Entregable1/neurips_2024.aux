\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Esquema de Convolución Multicanal 3D.} Ilustración de cómo un tensor de entrada de profundidad $C_{in}$ es procesado por filtros volumétricos. Cada filtro se extiende a través de toda la profundidad de la entrada, sumando las contribuciones para generar un único canal en el mapa de salida $S$.}}{5}{figure.2}\protected@file@percent }
\newlabel{fig:cnn_multicanal}{{2}{5}{\textbf {Esquema de Convolución Multicanal 3D.} Ilustración de cómo un tensor de entrada de profundidad $C_{in}$ es procesado por filtros volumétricos. Cada filtro se extiende a través de toda la profundidad de la entrada, sumando las contribuciones para generar un único canal en el mapa de salida $S$}{figure.2}{}}
