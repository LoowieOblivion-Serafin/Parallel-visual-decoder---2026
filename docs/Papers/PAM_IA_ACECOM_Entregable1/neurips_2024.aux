\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces \textbf  {Matriz de Similitud y Aprendizaje Contrastivo.} Representación de un lote de entrenamiento con $N$ pares imagen-texto. La cuadrícula representa la matriz de similitudes $N \times N$ calculada mediante el producto punto. Se busca maximizar los valores a lo largo de la diagonal principal y minimizar simultáneamente todos los valores fuera de la diagonal.}}{12}{figure.6}\protected@file@percent }
\newlabel{fig:clip_loss}{{6}{12}{\textbf {Matriz de Similitud y Aprendizaje Contrastivo.} Representación de un lote de entrenamiento con $N$ pares imagen-texto. La cuadrícula representa la matriz de similitudes $N \times N$ calculada mediante el producto punto. Se busca maximizar los valores a lo largo de la diagonal principal y minimizar simultáneamente todos los valores fuera de la diagonal}{figure.6}{}}
