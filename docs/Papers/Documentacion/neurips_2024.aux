\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Arquitectura de un Autoencoder Convolucional.} A diferencia de un AE estándar, el Encoder utiliza capas convolucionales para reducir progresivamente las dimensiones espaciales ($H \times W$) mientras extrae características semánticas, colapsando la imagen en un vector latente $z$. El Decoder realiza la operación inversa mediante \textit  {transposed convolutions} para recuperar la geometría original.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:conv_autoencoder}{{3}{8}{\textbf {Arquitectura de un Autoencoder Convolucional.} A diferencia de un AE estándar, el Encoder utiliza capas convolucionales para reducir progresivamente las dimensiones espaciales ($H \times W$) mientras extrae características semánticas, colapsando la imagen en un vector latente $z$. El Decoder realiza la operación inversa mediante \textit {transposed convolutions} para recuperar la geometría original}{figure.3}{}}
